{
  "info": {
    "_postman_id": "habit-tracker-simple-001",
    "name": "Habit Tracker Simple API",
    "description": "6 endpoint + auth flow — Newman ile CI'da koşar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "habit_id", "value": "" },
    { "key": "rand", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "1. Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"newman_{{rand}}\",\n  \"email\": \"newman_{{rand}}@x.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": ["pm.collectionVariables.set('rand', Math.random().toString(36).slice(2,10));"],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "pm.test('returns user id', () => pm.expect(pm.response.json().id).to.be.a('number'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newman_{{rand}}@x.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('access_token present', () => pm.expect(body.access_token).to.be.a('string'));",
            "pm.collectionVariables.set('token', body.access_token);"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "3. Create Habit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Run 5km\",\n  \"description\": \"Morning jog\",\n  \"category\": \"fitness\",\n  \"goal_days_per_week\": 5\n}"
        },
        "url": { "raw": "{{base_url}}/habits", "host": ["{{base_url}}"], "path": ["habits"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('habit id returned', () => pm.expect(body.id).to.be.a('number'));",
            "pm.collectionVariables.set('habit_id', body.id);"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "4. List Habits",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/habits", "host": ["{{base_url}}"], "path": ["habits"] }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('list non-empty', () => pm.expect(pm.response.json().length).to.be.above(0));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "5. Track Habit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"done\": true,\n  \"notes\": \"newman track\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/track",
          "host": ["{{base_url}}"],
          "path": ["habits", "{{habit_id}}", "track"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "pm.test('done=true persisted', () => pm.expect(pm.response.json().done).to.eql(true));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "6. Get Streak",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/streak",
          "host": ["{{base_url}}"],
          "path": ["habits", "{{habit_id}}", "streak"]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('streak >= 1', () => pm.expect(pm.response.json().current_streak).to.be.at.least(1));"
          ],
          "type": "text/javascript"
        }
      }]
    }
  ]
}
