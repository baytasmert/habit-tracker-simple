# ─── Habit Tracker — Tek Kaynak Konfigürasyon ───────────────
# Kullanım:  cp .env.example .env  → docker-compose up
# Backend, K8s ConfigMap ve docker-compose hepsi bu dosyadan okur.

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=habituser
POSTGRES_PASSWORD=habitpass
POSTGRES_DB=habits
DATABASE_URL=postgresql://habituser:habitpass@db:5432/habits

# ── Backend / Auth ───────────────────────────────────────────
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AWS S3 (LocalStack Community Edition) ───────────────────
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=habit-photos

# ── Tracing (OpenTelemetry → Jaeger) ────────────────────────
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=habit-tracker-backend

# ── Monitoring ──────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# admin.1234 → "admin" olmadığı için Grafana her girişte şifre değiştirmeye zorlamaz
GRAFANA_ADMIN_PASSWORD=admin.1234

# ── Korumalı paneller — Traefik BasicAuth (jaeger/prometheus/api) ──
# Bu .env.example bir ŞABLON'dur; gerçek şifreler buradan üretilir.
# Prod'da değiştir. Hash üretmek için: htpasswd -nbB <user> <şifre>
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=habit2026
